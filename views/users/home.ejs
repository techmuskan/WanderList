<% layout("layouts/boilerplate") -%>

<section class="dashboard-shell full-bleed">
  <div class="container">
    <div class="dashboard-grid">
      <div>
        <span class="greeting-pill"><i class="fa-solid fa-sparkles"></i><span id="greetingText">Welcome back</span></span>
        <h1 class="dashboard-title">Your travel dashboard, tuned like a compass.</h1>
        <p class="dashboard-lede">
          Plan fast, pin inspirations, and build a trip that feels made for you. WanderList now works like a
          creative studio for your next escape.
        </p>
        <div class="action-row">
          <a href="/listings" class="btn-ink">Explore Destinations</a>
          <a href="/listings/new" class="btn-outline">Share a Spot</a>
        </div>
      </div>
      <div class="panel-stack">
        <div class="dashboard-card">
          <div class="card-title">WanderPulse</div>
          <p class="mb-2">Live signals from the community today.</p>
        <div class="metric-grid">
          <div class="metric-chip">
            <h4 data-count="12840">0</h4>
            <span>Spots mapped</span>
          </div>
          <div class="metric-chip">
            <h4 data-count="762">0</h4>
            <span>New reviews</span>
          </div>
          <div class="metric-chip">
            <h4 data-count="148">0</h4>
            <span>Trips planned</span>
          </div>
        </div>
        <p class="text-muted mt-3 small" id="pulseLine">Live stats from the community today.</p>
      </div>
        <div class="dashboard-card">
          <div class="card-title">Trip Lab</div>
          <form class="planner-form" id="tripLabForm">
            <input type="text" name="origin" placeholder="Starting city" required>
            <select name="mood" required>
              <option value="coastal">Coastal calm</option>
              <option value="mountain">Mountain reset</option>
              <option value="city">City pulse</option>
              <option value="heritage">Heritage trail</option>
              <option value="wild">Wild escape</option>
            </select>
            <select name="pace" required>
              <option value="slow">Slow & soulful</option>
              <option value="balanced">Balanced</option>
              <option value="fast">Fast & active</option>
            </select>
            <button class="btn-ink" type="submit">Generate micro-itinerary</button>
          </form>
          <div class="planner-output" id="tripLabOutput">Pick a mood and let us sketch your next three days.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="trust-strip scroll-reveal">
      <div class="trust-item">
        <span class="trust-icon"><i class="fa-solid fa-shield"></i></span>
        <span>Secure‑ready checkout experience</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon"><i class="fa-solid fa-user-check"></i></span>
        <span>Host profiles with community reviews</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon"><i class="fa-solid fa-headset"></i></span>
        <span>Support when you need it</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon"><i class="fa-solid fa-clipboard-check"></i></span>
        <span>Clear listing details and policies</span>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title scroll-reveal">Explore by vibe</h2>
    <p class="section-sub scroll-reveal">Filter the community picks and pin what feels right for this season.</p>
    <div class="vibe-row" id="vibeRow"></div>
    <div class="dest-grid" id="destGrid"></div>
    <div class="d-flex justify-content-end mt-4">
      <a class="btn-ink" href="/signup">See more</a>
    </div>
  </div>
</section>

<section class="section full-bleed">
  <div class="container">
    <div class="dashboard-card scroll-reveal">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
          <h3 class="card-title mb-1">Roll the Dice</h3>
          <p class="text-muted mb-0">Tap the dice and discover a fresh place every time.</p>
        </div>
        <button class="btn-ink" id="diceBtn" type="button">
          <i class="fa-solid fa-dice me-2"></i>Tap Dice
        </button>
      </div>
      <div class="row mt-4 align-items-stretch" id="diceResult"></div>
    </div>
  </div>
</section>

<section class="section full-bleed">
  <div class="container">
    <div class="row g-4 align-items-stretch">
      <div class="col-lg-7">
        <div class="dashboard-card scroll-reveal">
          <h3 class="card-title">My Pinboard</h3>
          <p class="text-muted">Save ideas while you browse. This board stays with you.</p>
          <div class="board" id="pinBoard">
            <div class="board-item">No pins yet. Tap "Pin" on a destination.</div>
          </div>
          <button class="board-clear mt-3" id="clearPinsBtn" type="button">Clear board</button>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="dashboard-card scroll-reveal">
          <h3 class="card-title">Quick tools</h3>
          <div class="tool-grid">
            <div>
              <strong>Budget tracker</strong>
              <p class="text-muted mb-2">Set a target and see how it breaks down.</p>
              <input class="form-control mb-2" id="budgetInput" type="number" min="100" placeholder="Total budget">
              <button class="btn-ink" id="budgetBtn" type="button">Split budget</button>
              <div class="planner-output mt-2" id="budgetOutput">Lodging, food, and fun split will appear here.</div>
            </div>
            <div>
              <strong>Essentials checklist</strong>
              <div id="checklist"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="cta-band scroll-reveal">
      <h2 class="section-title">Ready to publish your next discovery?</h2>
      <p>Bring the community somewhere new and collect fresh stories on the map.</p>
      <a class="btn-ink" href="/listings/new">Share Your Spot</a>
    </div>
  </div>
</section>

<script>
  const revealNodes = document.querySelectorAll(".scroll-reveal");
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add("active");
    });
  }, { threshold: 0.2 });
  revealNodes.forEach(node => revealObserver.observe(node));

  const greetingText = document.getElementById("greetingText");
  const hour = new Date().getHours();
  const greeting = hour < 12 ? "Good morning" : hour < 18 ? "Good afternoon" : "Good evening";
  greetingText.textContent = `${greeting}, explorer`;

  const counters = document.querySelectorAll("[data-count]");
  const runCounter = (el) => {
    const target = Number(el.dataset.count);
    const step = Math.max(1, Math.floor(target / 120));
    let current = 0;
    const update = () => {
      current += step;
      if (current < target) {
        el.textContent = current.toLocaleString();
        requestAnimationFrame(update);
      } else {
        el.textContent = target.toLocaleString();
      }
    };
    update();
  };
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) runCounter(entry.target);
    });
  }, { threshold: 0.4 });
  counters.forEach(c => counterObserver.observe(c));
  const isAuthed = <%- currentUser ? 'true' : 'false' %>;
  let destinations = [];
  let tripLabData = {};
  let pins = [];
  let checklistState = {};

  const vibeLabels = {
    all: "All vibes",
    coastal: "Coastal calm",
    mountain: "Mountain reset",
    city: "City pulse",
    heritage: "Heritage trail",
    wild: "Wild escape"
  };

  const vibeRow = document.getElementById("vibeRow");
  const destGrid = document.getElementById("destGrid");
  let activeVibe = "all";

  const renderVibes = () => {
    vibeRow.innerHTML = "";
    Object.entries(vibeLabels).forEach(([key, label]) => {
      const chip = document.createElement("button");
      chip.type = "button";
      chip.className = `vibe-chip ${activeVibe === key ? "active" : ""}`;
      chip.textContent = label;
      chip.addEventListener("click", () => {
        activeVibe = key;
        renderVibes();
        renderDestinations();
      });
      vibeRow.appendChild(chip);
    });
  };

  const getMaxCards = () => {
    const w = window.innerWidth;
    if (w < 576) return 5;
    if (w < 992) return 8;
    return 10;
  };

  const renderDestinations = () => {
      const filtered = activeVibe === "all"
        ? destinations
        : destinations.filter(dest => dest.vibe === activeVibe);
    const maxCards = getMaxCards();
    destGrid.innerHTML = "";
    filtered.slice(0, maxCards).forEach(dest => {
      const card = document.createElement("article");
      card.className = "dest-card";
      card.innerHTML = `
        <span class="dest-tag">${dest.tag}</span>
        <h4>${dest.name}</h4>
        <div class="text-muted">${dest.country}</div>
        <div class="text-muted small">${dest.location}</div>
        <button class="pin-btn" type="button">Pin to board</button>
      `;
      card.querySelector(".pin-btn").addEventListener("click", () => addPin(dest));
      destGrid.appendChild(card);
    });
  };

  const diceBtn = document.getElementById("diceBtn");
  const diceResult = document.getElementById("diceResult");
  const renderDiceCard = (place, photo) => {
    if (!place) {
      diceResult.innerHTML = "<p class='text-muted'>No places available yet. Add a listing first.</p>";
      return;
    }
    const imgUrl = photo?.url || place.imageUrl;
    const credit = photo?.photographer
      ? `<div class="text-muted small mt-2">Photo by <a href="${photo.photographerUrl}" target="_blank" rel="noopener">${photo.photographer}</a></div>`
      : "";
    const detailButtons = isAuthed
      ? `<a class="btn-outline" href="/listings/${place.id}">View details</a>`
      : `<div class="d-flex gap-2 flex-wrap">
           <a class="btn-outline" href="/login">Login</a>
           <a class="btn-ink" href="/signup">Sign up</a>
         </div>`;
    diceResult.innerHTML = `
      <div class="col-lg-7">
        <div class="dest-card h-100">
          <span class="dest-tag">${place.tag}</span>
          <h4>${place.name}</h4>
          <div class="text-muted">${place.location}, ${place.country}</div>
          <div class="text-muted small mt-2">Perfect for a ${place.vibe} vibe</div>
          <div class="mt-3">${detailButtons}</div>
          ${credit}
        </div>
      </div>
      <div class="col-lg-5">
        <div class="dashboard-card h-100">
          <img src="${imgUrl}" alt="${place.name}" style="width:100%;height:220px;object-fit:cover;border-radius:16px;">
        </div>
      </div>
    `;
  };

  const pinKey = "wanderlistPins";
  const pinBoard = document.getElementById("pinBoard");
  const clearPinsBtn = document.getElementById("clearPinsBtn");

  const loadLocalPins = () => {
    try {
      return JSON.parse(localStorage.getItem(pinKey)) || [];
    } catch (err) {
      return [];
    }
  };

  const saveLocalPins = (nextPins) => {
    localStorage.setItem(pinKey, JSON.stringify(nextPins));
  };

  const showPinGuard = () => {
    alert("Please login or sign up to pin destinations.");
  };

  const addPin = async (dest) => {
    if (!isAuthed) {
      showPinGuard();
      return;
    }
    const response = await fetch("/dashboard/pins", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ listingId: dest.id })
    });
    if (response.ok) {
      const data = await response.json();
      if (!pins.find(pin => pin.id === data.pin.id)) {
        pins.push(data.pin);
      }
      renderPins();
    }
  };

  const removePin = async (id) => {
    if (!isAuthed) {
      showPinGuard();
      return;
    }
    const response = await fetch(`/dashboard/pins/${id}`, { method: "DELETE" });
    if (response.ok) {
      pins = pins.filter(pin => pin.id !== id);
      renderPins();
    }
  };

  const renderPins = () => {
    pinBoard.innerHTML = "";
    if (pins.length === 0) {
      pinBoard.innerHTML = "<div class='board-item'>No pins yet. Tap \"Pin\" on a destination.</div>";
      return;
    }
    pins.forEach(pin => {
      const row = document.createElement("div");
      row.className = "board-item";
      row.innerHTML = `
        <span>${pin.name}, ${pin.country}</span>
        <button class="board-clear" type="button">Remove</button>
      `;
      row.querySelector("button").addEventListener("click", () => removePin(pin.id));
      pinBoard.appendChild(row);
    });
  };

  clearPinsBtn.addEventListener("click", async () => {
    if (!isAuthed) {
      showPinGuard();
      return;
    }
    await Promise.all(pins.map(pin => fetch(`/dashboard/pins/${pin.id}`, { method: "DELETE" })));
    pins = [];
    renderPins();
  });

  const tripLabForm = document.getElementById("tripLabForm");
  const tripLabOutput = document.getElementById("tripLabOutput");

  const moodCopy = {
    coastal: ["Sunrise shoreline walk", "Seafood market lunch", "Golden hour on the pier"],
    mountain: ["Forest trail warm-up", "Scenic ridge picnic", "Hot chai by the valley"],
    city: ["Design district stroll", "Street food safari", "Jazz or rooftop night"],
    heritage: ["Temple + bazaar loop", "Museum deep dive", "Storytelling cafe"],
    wild: ["Waterfall chase", "Lakeside reset", "Night sky lookout"]
  };

  const countryKeywords = [
    { key: 'united states', val: 'United States' },
    { key: 'usa', val: 'United States' },
    { key: 'u.s', val: 'United States' },
    { key: 'us', val: 'United States' },
    { key: 'india', val: 'India' },
    { key: 'mexico', val: 'Mexico' },
    { key: 'switzerland', val: 'Switzerland' },
    { key: 'italy', val: 'Italy' },
    { key: 'tanzania', val: 'Tanzania' },
    { key: 'netherlands', val: 'Netherlands' },
    { key: 'uk', val: 'United Kingdom' },
    { key: 'united kingdom', val: 'United Kingdom' },
    { key: 'uae', val: 'United Arab Emirates' },
    { key: 'australia', val: 'Australia' },
    { key: 'canada', val: 'Canada' },
    { key: 'japan', val: 'Japan' }
  ];

  const cityToCountry = {
    "new york": "United States",
    "los angeles": "United States",
    "miami": "United States",
    "san francisco": "United States",
    "malibu": "United States",
    "delhi": "India",
    "mumbai": "India",
    "pune": "India",
    "jaipur": "India",
    "goa": "India",
    "rishikesh": "India",
    "udaipur": "India",
    "coorg": "India",
    "mathura": "India",
    "amsterdam": "Netherlands",
    "florence": "Italy",
    "verbier": "Switzerland",
    "cancun": "Mexico",
    "serengeti": "Tanzania"
  };

  const inferCountryFromOrigin = (origin) => {
    const o = origin.toLowerCase().trim();
    if (!o) return '';
    const byCountry = countryKeywords.find(c => o.includes(c.key));
    if (byCountry) return byCountry.val;
    const cityKey = Object.keys(cityToCountry).find(c => o.includes(c));
    return cityKey ? cityToCountry[cityKey] : '';
  };

  const pickItinerary = (origin, mood) => {
    const originLower = origin.toLowerCase().trim();
    const preferredCountry = inferCountryFromOrigin(origin);
    const moodDestinations = destinations.filter(d => d.vibe === mood || mood === 'all');
    const sameCity = originLower
      ? moodDestinations.filter(d =>
          (d.location || '').toLowerCase().includes(originLower) ||
          (d.country || '').toLowerCase().includes(originLower)
        )
      : [];
    const sameCountry = preferredCountry
      ? moodDestinations.filter(d => (d.country || '').toLowerCase() === preferredCountry.toLowerCase())
      : [];
    const pool = (sameCity.length ? sameCity : sameCountry.length ? sameCountry : moodDestinations);
    return pool.slice(0, 3);
  };

  tripLabForm.addEventListener("submit", (event) => {
    event.preventDefault();
    const formData = new FormData(tripLabForm);
    const origin = formData.get("origin");
    const mood = formData.get("mood");
    const pace = formData.get("pace");
    const picks = pickItinerary(origin || '', mood);
    const basePlan = picks.length
      ? [
          `Arrive in ${picks[0].location} and check in at ${picks[0].name}`,
          picks[1] ? `Signature moment near ${picks[1].location}` : "Signature experience",
          picks[2] ? `Slow evening in ${picks[2].location}` : "Farewell moments"
        ]
      : (moodCopy[mood] || []);
    const paceLine = pace === "fast"
      ? "Packed days, minimal downtime."
      : pace === "slow"
      ? "Leave room to wander and linger."
      : "A balanced flow with easy breaks.";
    tripLabOutput.innerHTML = `
      <strong>3-day sketch from ${origin}:</strong><br>
      Day 1: ${basePlan[0] || "Arrival and local stroll"}<br>
      Day 2: ${basePlan[1] || "Signature experience"}<br>
      Day 3: ${basePlan[2] || "Farewell moments"}<br>
      <em>${paceLine}</em>
    `;
  });

  const budgetBtn = document.getElementById("budgetBtn");
  const budgetInput = document.getElementById("budgetInput");
  const budgetOutput = document.getElementById("budgetOutput");

  budgetBtn.addEventListener("click", () => {
    const total = Number(budgetInput.value);
    if (!total || total < 100) {
      budgetOutput.textContent = "Enter a budget of at least 100.";
      return;
    }
    const lodging = Math.round(total * 0.45);
    const food = Math.round(total * 0.3);
    const fun = total - lodging - food;
    budgetOutput.textContent = `Lodging: ${lodging} | Food: ${food} | Experiences: ${fun}`;
  });

  const checklistItems = [
    "Passport or ID",
    "Chargers + adapters",
    "Weather layer",
    "Offline map saved",
    "Essential meds"
  ];
  const checklistEl = document.getElementById("checklist");

  const renderChecklist = () => {
    checklistEl.innerHTML = "";
    checklistItems.forEach(item => {
      const row = document.createElement("label");
      row.className = "checklist-item";
      const checked = Boolean(checklistState[item]);
      row.innerHTML = `
        <input type="checkbox" ${checked ? "checked" : ""}>
        <span>${item}</span>
      `;
      row.querySelector("input").addEventListener("change", async (event) => {
        checklistState[item] = event.target.checked;
        if (isAuthed) {
          await fetch("/dashboard/checklist", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ item, checked: event.target.checked })
          });
        } else {
          localStorage.setItem("wanderlistChecklist", JSON.stringify(checklistState));
        }
      });
      checklistEl.appendChild(row);
    });
  };

  const loadDashboard = async () => {
    try {
      const response = await fetch("/dashboard/data");
      if (response.ok) {
        const data = await response.json();
        destinations = data.destinations || [];
        tripLabData = data.tripLab || {};
        pins = data.pins || [];
        checklistState = data.checklist || {};
        const metrics = data.metrics || {};
        if (metrics.listings) document.querySelector('[data-count="12840"]').dataset.count = metrics.listings;
        if (metrics.reviews) document.querySelector('[data-count="762"]').dataset.count = metrics.reviews;
        if (metrics.users) document.querySelector('[data-count="148"]').dataset.count = metrics.users;
        const pulseLine = document.getElementById("pulseLine");
        if (pulseLine && metrics.listings && metrics.reviews) {
          pulseLine.textContent = `${metrics.listings} spots mapped · ${metrics.reviews} reviews logged · ${metrics.users || 0} explorers active`;
        }
        // Re-run counters after async data load
        counters.forEach(c => {
          c.textContent = "0";
          runCounter(c);
        });
      }
    } catch (err) {
      destinations = [];
    }

    if (!isAuthed) {
      pins = loadLocalPins();
      try {
        checklistState = JSON.parse(localStorage.getItem("wanderlistChecklist")) || {};
      } catch (err) {
        checklistState = {};
      }
    }
    renderVibes();
    renderDestinations();
    renderPins();
    renderChecklist();
  };

  loadDashboard();
  diceBtn.addEventListener("click", async () => {
    if (!destinations.length) return renderDiceCard(null);
    const pick = destinations[Math.floor(Math.random() * destinations.length)];
    const query = `${pick.location} ${pick.country}`;
    try {
      const resp = await fetch(`/api/pexels?q=${encodeURIComponent(query)}`);
      if (resp.ok) {
        const photo = await resp.json();
        return renderDiceCard(pick, photo);
      }
    } catch (err) {}
    renderDiceCard(pick);
  });
  window.addEventListener('resize', () => {
    renderDestinations();
  });
</script>
