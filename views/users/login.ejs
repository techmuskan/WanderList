<% layout("/layouts/boilerplate") %>
<section class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-11 col-md-7 col-lg-5">
        <div class="dashboard-card">
          <span class="greeting-pill"><i class="fa-solid fa-sparkles"></i>Welcome back</span>
          <h2 class="section-title">Login to WanderList</h2>
          <p class="section-sub">Pick up where your last trip left off.</p>
          <form action="/login" method="POST" class="needs-validation mt-3" novalidate>
            <div class="mb-3">
              <label for="identifier" class="form-label">Username or Email</label>
              <input type="text" class="form-control" id="identifier" name="identifier" required>
              <div class="invalid-feedback">Please provide a valid username or email.</div>
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <div class="input-group">
                <input type="password" class="form-control" id="password" name="password" required>
                <button class="btn btn-outline-secondary" type="button" id="toggleLoginPass" aria-label="Toggle password visibility">
                  <i class="fa-regular fa-eye"></i>
                </button>
              </div>
              <div class="invalid-feedback">Please provide a valid password.</div>
            </div>
            <button class="btn-ink w-100" type="submit">Login</button>
          </form>
          <p class="mt-3 text-center">
            Don't have an account? <a href="/signup">Create one</a>
          </p>
          <p class="text-center">
            <a href="/forgot">Forgot password?</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const loginPass = document.getElementById('password');
  const toggleLoginPass = document.getElementById('toggleLoginPass');
  toggleLoginPass.addEventListener('click', () => {
    const isPwd = loginPass.type === 'password';
    loginPass.type = isPwd ? 'text' : 'password';
    toggleLoginPass.innerHTML = isPwd
      ? '<i class="fa-regular fa-eye-slash"></i>'
      : '<i class="fa-regular fa-eye"></i>';
  });
</script>
