      <h5 class="footer-title">WanderList</h5>
      <p class="footer-text">
        Curated stays, city pulses, and slow escapes — built for modern explorers.
      </p>
      <div class="footer-badges">
        <span class="badge-pill">Handpicked</span>
        <span class="badge-pill">Community‑rated</span>
        <span class="badge-pill">Secure</span>
      </div>
    </div>

    <!-- Links -->
    <div class="footer-section">
      <h5 class="footer-title">Explore</h5>
      <ul class="footer-links">
        <li><a href="/listings">All Listings</a></li>
        <li><a href="/listings?category=Beachfront">Beachfront</a></li>
        <li><a href="/listings?category=Mountains">Mountains</a></li>
        <li><a href="/listings?category=Iconic%20Cities">Iconic Cities</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h5 class="footer-title">Account</h5>
      <ul class="footer-links">
        <li><a href="/signup">Create account</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/forgot">Reset password</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <!-- Social -->
    <div class="footer-section">
      <h5 class="footer-title">Follow</h5>
      <div class="social-icons">
        <a href="https://www.facebook.com" class="social-icon" aria-label="Facebook" target="_blank" rel="noopener"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="https://twitter.com" class="social-icon" aria-label="X" target="_blank" rel="noopener"><i class="fa-brands fa-x-twitter"></i></a>
        <a href="https://www.instagram.com" class="social-icon" aria-label="Instagram" target="_blank" rel="noopener"><i class="fa-brands fa-instagram"></i></a>
        <a href="https://www.linkedin.com" class="social-icon" aria-label="LinkedIn" target="_blank" rel="noopener"><i class="fa-brands fa-linkedin-in"></i></a>
      </div>
      <p class="footer-text tiny">Weekly drops, trail tips, and host stories.</p>
    </div>
  </div>

  <hr>

  <div class="footer-bottom">
    &copy; <%= new Date().getFullYear() %> WanderList. All rights reserved.
  </div>
</footer>

<style>
  /* Footer Base */
  #site-footer {
    background:
      radial-gradient(circle at 10% 0%, rgba(247,213,122,0.18), transparent 35%),
      radial-gradient(circle at 90% 20%, rgba(45,139,144,0.18), transparent 40%),
      linear-gradient(135deg, #1b1a18, #2b2a27 60%, #1b1a18);
    color: #fff;
    padding: 36px 28px;
    box-shadow: 0 -6px 18px rgba(0,0,0,0.24);
    width: 100%;
    z-index: 1000;
  }


  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 18px 28px;
  }

  .footer-section {
    flex: 1 1 210px;
    min-width: 210px;
  }

  .footer-section.brand {
    flex: 1.2 1 260px;
  }

  .center {
    text-align: center;
  }

  .footer-title {
    color: #f7d57a;
    margin-bottom: 8px;
    letter-spacing: 0.3px;
    font-size: 1.05rem;
  }

  .footer-text {
    font-size: 0.88rem;
    line-height: 1.5;
    color: #d6d6d6;
  }

  .footer-text.tiny {
    font-size: 0.78rem;
    color: #bdbdbd;
    margin-top: 10px;
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .badge-pill {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    color: #fff;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.2px;
  }

  /* Links */
  .footer-links {
    list-style: none;
    padding: 0;
    font-size: 0.86rem;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 8px;
  }

  footer a {
    color: #fff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  footer a:hover {
    color: #f7d57a;
  }

  /* Social */
  .social-icons {
    display: flex;
    justify-content: center;
    gap: 15px;
    font-size: 1.3rem;
  }

  .social-icon {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .social-icon:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 22px rgba(247,213,122,0.45);
    border-radius: 50%;
  }

  /* Divider and Bottom */
  hr {
    border-color: #2f2f2f;
    margin: 18px 0;
  }

  .footer-bottom {
    text-align: center;
    font-size: 0.78rem;
    color: #a9a9a9;
  }

  /* Fade Animation */
  .fade-footer {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .fade-footer.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    #site-footer {
      padding: 20px 14px;
    }

    .footer-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-title {
      font-size: 0.95rem;
      margin-bottom: 4px;
    }

    .footer-text,
    .footer-links {
      font-size: 0.78rem;
    }

    .social-icons {
      font-size: 1.2rem;
    }

    hr {
      margin: 14px 0;
    }

    .footer-section {
      min-width: auto;
      width: 100%;
    }

    .footer-badges {
      justify-content: center;
    }

    .footer-links li {
      margin-bottom: 4px;
    }
  }

  @media (max-width: 480px) {
    #site-footer {
      padding: 22px 14px;
    }

    .footer-title {
      font-size: 1rem;
    }

    .footer-text,
    .footer-links {
      font-size: 0.8rem;
      line-height: 1.4;
    }

    .social-icons {
      font-size: 1.1rem;
      gap: 10px;
    }

    hr {
      margin: 15px 0;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const footer = document.getElementById("site-footer");
    if (!footer) return;

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) footer.classList.add("visible");
      });
    }, { threshold: 0.1 });

    observer.observe(footer);
  });
</script>
