<% 
  const route = typeof currentRoute !== 'undefined' ? currentRoute : '';
%>

<style>
/* =========================
   Navbar (Clean SaaS)
========================= */
.navbar {
  padding: 0.75rem 1.1rem;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
}

.navbar-brand {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0.2px;
  color: #0f172a !important;
}

.brand-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.28rem 0.75rem;
  border-radius: 999px;
  background: rgba(37,99,235,0.1);
  border: 1px solid rgba(37, 99, 235, 0.2);
}

.navbar-nav .nav-link {
  margin-right: 0;
  padding: 0.4rem 0.75rem;
  border-radius: 10px;
  text-align: center;
  white-space: nowrap;
  color: #0f172a !important;
  transition: background 0.2s ease, color 0.2s ease;
}

.navbar-nav .nav-link:last-child {
  margin-right: 0;
}

.navbar-nav {
  gap: 0.4rem;
}

.navbar-nav .nav-link.active {
  background: rgba(15, 23, 42, 0.08);
  color: #0f172a !important;
}

.navbar-nav .nav-link:hover {
  background: rgba(15, 23, 42, 0.06);
  color: #0f172a !important;
}

.nav-cta {
  background: transparent;
  color: #0f172a !important;
  border-radius: 10px;
  padding: 0.4rem 0.75rem;
  box-shadow: none;
  border: none;
}

.nav-cta:hover {
  background: rgba(15, 23, 42, 0.06);
  color: #0f172a !important;
}

.search-input {
  border-radius: 999px;
  padding: 0.5rem 0.9rem;
  font-size: 0.95rem;
  min-width: 240px;
  border: 1px solid rgba(15, 23, 42, 0.12);
  background: #fff;
}

.btn-search {
  background: #0f172a;
  color: white;
  border-radius: 10px;
  padding: 0.5rem 0.9rem;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 8px 18px rgba(15, 23, 42, 0.16);
}

.btn-search:hover {
  transform: translateY(-1px);
  color: #fff;
}

.btn-search i {
  margin-right: 0.5rem;
}

.profile-pill {
  display: inline-flex;
  align-items: center;
  padding: 0;
  border-radius: 0;
  background: transparent !important;
  box-shadow: none !important;
}

.pill-avatar {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: #0f172a;
  border: 1px solid rgba(15, 23, 42, 0.25);
  display: grid;
  place-items: center;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  line-height: 1;
  font-size: 0.85rem;
  letter-spacing: 0.02em;
}

.pill-avatar:hover {
  filter: brightness(1.05);
}

.profile-pill:hover {
  background: transparent !important;
}

/* =========================
   Tablets: 768px–960px
========================= */
@media (min-width: 768px) and (max-width: 960px) {
  .navbar {
    flex-wrap: nowrap; /* prevent wrapping */
  }

  .navbar-nav.me-auto,
  .navbar-nav.mx-auto,
  .navbar-nav.ms-auto {
    flex-direction: row; /* keep all links inline */
    align-items: center;
    justify-content: flex-start;
  }

  .navbar-nav.mx-auto {
    flex: 1 1 auto; /* take remaining space for search bar */
    justify-content: center;
  }

  form.d-flex {
    flex-direction: row;
    gap: 0.3rem;
    flex-wrap: nowrap;
    width: 100%;
    justify-content: center;
  }

  .search-input {
    min-width: 180px;
    font-size: 0.9rem;
  }

  .btn-search {
    font-size: 0.85rem;
    padding: 0.3rem 0.7rem;
  }

  .navbar-nav .nav-link {
    font-size: 0.85rem;
    margin: 0 0.3rem;
    padding: 0.25rem 0.5rem;
  }
}

/* =========================
   Medium & Small Screens <=767px
========================= */
@media (max-width: 767px) {
  .navbar-collapse {
    flex-wrap: wrap; /* allow collapse to stack items */
  }

  .navbar-nav {
    flex-direction: column;
    width: 100%;
  }

  .navbar-nav .nav-link {
    margin: 0.15rem 0;
    border-radius: 12px;
    width: 100%;
    text-align: left;
    padding: 0.4rem 0.6rem;
  }

  form.d-flex {
    flex-direction: column;
    width: 100%;
  }

  .search-input, .btn-search {
    width: 100%;
    margin-bottom: 0.3rem;
  }

  .navbar-brand {
    font-size: 1.2rem;
  }

  .brand-pill {
    padding: 0.2rem 0.6rem;
  }

  .nav-cta {
    width: 100%;
    text-align: center;
    padding: 0.4rem 0.6rem;
  }
}

/* =========================
   Extra Small Screens <=480px
========================= */
@media (max-width: 480px) {
  .navbar-brand {
    font-size: 1.1rem;
  }

  .navbar-nav .nav-link {
    font-size: 0.9rem;
  }

  .search-input {
    min-width: 150px;
  }

  .btn-search {
    font-size: 0.9rem;
    padding: 0.4rem 1rem;
  }
}

</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/" aria-label="WanderList">
      <span class="brand-pill"><i class="fa-solid fa-compass"></i>WanderList</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <!-- Left links -->
      <div class="navbar-nav me-auto">
        <a class="nav-link <%= route === '/listings' ? 'active' : '' %>" href="/listings"><b>Explore</b></a>
        <a class="nav-link <%= route === '/contact' ? 'active' : '' %>" href="/contact"><b>Contact</b></a>
      </div>

      <!-- Search bar -->
      <div class="navbar-nav mx-auto my-2 my-md-0">
        <form class="d-flex flex-md-row flex-column" role="search" action="/listings" method="get">
          <input type="search" name="q" class="form-control me-md-2 mb-2 mb-md-0 search-input"
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
            placeholder="Search destinations">
          <button class="btn btn-search" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>Search
          </button>
        </form>
      </div>

      <!-- Right links -->
      <div class="navbar-nav ms-auto">
        <% if(currentUser) { %>
          <a class="nav-link profile-pill <%= route === '/profile' ? 'active' : '' %>" href="/profile" aria-label="Profile">
            <% 
              const initials = (currentUser.username || "U")
                .trim()
                .split(/\s+/)
                .slice(0, 2)
                .map(part => part[0]?.toUpperCase())
                .join("");
            %>
            <span class="pill-avatar"><%= initials || "U" %></span>
          </a>
          <a class="nav-link <%= route === '/listings/new' ? 'active' : '' %>" href="/listings/new"><b>Share Your Spot</b></a>
          <a class="nav-link" href="/logout"><b>Logout</b></a>
        <% } else { %>
          <a class="nav-link <%= route === '/signup' ? 'active' : '' %>" href="/signup"><b>SignUp</b></a>
          <a class="nav-link nav-cta <%= route === '/login' ? 'active' : '' %>" href="/login"><b>Login</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
